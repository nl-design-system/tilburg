    "@angular/platform-browser-dynamic": "20.3.9",
    "@gemeente-tilburg/components-angular": "workspace:*",
    "@gemeente-tilburg/components-css": "workspace:*",
    "@gemeente-tilburg/design-tokens": "workspace:*",
    "@gemeente-tilburg/font": "workspace:*",
