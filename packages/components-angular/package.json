{
  "name": "@gemeente-tilburg/components-angular",
  "version": "0.0.0",
  "description": "Angular web components for the Municipality of Tilburg based on the NL Design System architecture",
  "license": "EUPL-1.2",
  "keywords": [
    "nl-design-system"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:nl-design-system/tilburg.git",
    "directory": "packages/components-angular"
  },
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run '/^build:.*/' --passWithNoTests",
    "build:components": "ng build && pnpm test-results",
    "clean": "rimraf dist/ .angular/",
    "lint": "pnpm run '/^lint:.*/'",
    "lint:ts": "tsc --noEmit --project tsconfig.json",
    "watch:build": "ng build --watch",
    "test-results": "jest --json --outputFile=dist/.jest-test-results.json --silent --passWithNoTests",
    "test": "jest --verbose --passWithNoTests",
    "test-build": "node test-exports.mjs",
    "watch:test": "NODE_OPTIONS=--experimental-vm-modules jest --verbose --watch"
  },
  "dependencies": {
    "tslib": "2.8.1"
  },
  "peerDependencies": {
    "@utrecht/component-library-angular": "1.1.0",
    "@utrecht/design-tokens": "1.0.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.9",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/animations": "20.3.9",
    "@angular/cli": "20.3.9",
    "@angular/common": "20.3.9",
    "@angular/compiler": "20.3.9",
    "@angular/compiler-cli": "20.3.9",
    "@angular/core": "20.3.9",
    "@angular/forms": "20.3.9",
    "@angular/platform-browser": "20.3.9",
    "@angular/platform-browser-dynamic": "20.3.9",
    "@angular/router": "20.3.9",
    "@testing-library/angular": "17.3.1",
    "@testing-library/jest-dom": "6.6.3",
    "@gemeente-tilburg/design-tokens": "workspace:*",
    "@types/node": "22.10.1",
    "@types/jest": "29.5.14",
    "@typescript-eslint/eslint-plugin": "8.15.0",
    "@typescript-eslint/parser": "8.15.0",
    "@utrecht/component-library-angular": "1.1.0",
    "@utrecht/design-tokens": "1.0.0",
    "eslint": "9.15.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-json": "4.0.1",
    "eslint-plugin-prettier": "5.2.1",
    "jest": "29.7.0",
    "jest-preset-angular": "14.6.2",
    "lodash.clonedeepwith": "4.5.0",
    "lodash.isequal": "4.5.0",
    "ng-packagr": "20.0.0",
    "npm-run-all": "4.1.5",
    "pnpm": "9.15.0",
    "prettier": "3.4.2",
    "rxjs": "7.8.1",
    "typescript": "5.9.3",
    "zone.js": "0.15.0"
  },
  "module": "dist/fesm2022/gemeente-tilburg-components-angular.mjs",
  "typings": "dist/index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./dist/package.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "esm2022": "./dist/esm2022/gemeente-tilburg-components-angular.mjs",
      "esm": "./dist/esm2022/gemeente-tilburg-components-angular.mjs",
      "default": "./dist/fesm2022/gemeente-tilburg-components-angular.mjs"
    },
    "./src/design-tokens.css": {
      "default": "./src/design-tokens.css"
    },
    "./dist/src/design-tokens.css": {
      "default": "./dist/src/design-tokens.css"
    }
  }
}
